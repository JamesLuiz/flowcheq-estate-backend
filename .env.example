# =============================================================================
# Flowcheq Estate — Backend API (.env.example)
# =============================================================================
# Copy to `.env` in this folder (same directory as package.json):
#   cp .env.example .env
#
# Never commit `.env` — it is gitignored.
# Production: set these in your host (Railway, Render, VPS, Docker secrets, etc.)
# =============================================================================

# --- Required ---

# MongoDB connection string
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/flowcheq_estate?retryWrites=true&w=majority

# JWT signing secret — use a long random string (openssl rand -base64 48)
JWT_SECRET=change-me-to-a-long-random-secret

# Public web app URL (used in email links, CORS-related redirects)
CLIENT_ORIGIN=https://estate.flowcheq.com

# Public URL of this API (payment callbacks, webhooks, Flutterwave redirects)
API_BASE_URL=https://api.estate.flowcheq.com

# Same as CLIENT_ORIGIN in most setups; used for viewing/payment return URLs
FRONTEND_URL=https://estate.flowcheq.com

# HTTP port (default 3000)
PORT=3000

# --- Email (SMTP) — required for verification emails, partner leads, viewings ---

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user@example.com
SMTP_PASS=your-smtp-app-password
SMTP_FROM="Flowcheq Estate <no-reply@estate.flowcheq.com>"

# Inbox for admin notifications (new registrations, partner leads)
ADMIN_EMAIL=ops@estate.flowcheq.com

# --- Media uploads (Cloudinary) — required for listing photos ---

CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# --- Realtime chat (Pusher) — optional; Socket.IO also handles notifications ---

PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=mt1

# --- Payments (Flutterwave) — optional until you enable promotions/wallets/viewing fees ---

FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_ENCRYPTION_KEY=
FLUTTERWAVE_WEBHOOK_URL=https://api.estate.flowcheq.com/webhooks/flutterwave

# Platform bank account for split payouts (optional)
PLATFORM_BANK_CODE=
PLATFORM_ACCOUNT_NUMBER=
PLATFORM_ACCOUNT_NAME=Flowcheq Estate

# Platform fee on viewing/inspection payments (percentage, default 10)
VIEWING_FEE_PERCENTAGE=10

# --- Maps (server-side geocoding) — optional ---

# Google Maps Geocoding API (server-side reverse geocode for photo GPS verification)
# Enable: Geocoding API (Places is used on the web client)
GOOGLE_MAPS_API_KEY=

# --- Identity KYC (Youverify) — optional; account verification for landlords/agents ---

YOVERIFY_API_KEY=
YOVERIFY_BASE_URL=https://api.youverify.co
YOVERIFY_WEBHOOK_SECRET=

# --- Telegram bot (optional; separate Python service in bot/) ---

BOT_TOKEN=

# --- Node ---

NODE_ENV=production
